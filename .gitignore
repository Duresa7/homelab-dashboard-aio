# Dependencies
node_modules

# Build output
/dist
*.tsbuildinfo

# Runtime data (SQLite, HLS scratch, etc.)
/data
*.sqlite
*.sqlite-journal
*.sqlite-wal

# Test coverage
coverage

# Environment (never commit real secrets — keep only the example template)
.env
.env.*
!.env.example

# Logs
*.log

# Reference docs (local only)
docs/*
# ...except agent-skills config + architecture decision records, shared with the repo
!docs/agents/
!docs/adr/

# Personal / local-only tooling
.claude/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/*
!.vscode/extensions.json
.idea
*.local

# Secrets, keys, certs (defense-in-depth — this app uses SSH keys)
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
id_rsa*
id_ed25519*
id_homelab*
*.ppk
secrets/
*.secret

# Security scan / audit reports — these enumerate open vulnerabilities; never
# commit them to a public repo.
security-audit/
*-security-audit.md

# Local-only compose/config overrides (often hold real hosts/paths)
docker-compose.override.yml
docker-compose.*.local.yml

# Backups / swap / temp
*.bak
*.backup
*.orig
*~
*.swp
*.tmp
