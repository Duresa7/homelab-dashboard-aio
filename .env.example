# Force every integration off, regardless of individual *_ENABLED flags.
DISABLE_ALL=false

# UniFi Controller
UNIFI_ENABLED=false
UNIFI_BASE_URL=
UNIFI_API_KEY=
UNIFI_SITE=default
UNIFI_POLL_INTERVAL=2000

# Proxmox VE
# TOKEN_ID format: user@realm!tokenname (e.g. root@pam!dashboard)
PROXMOX_ENABLED=false
PROXMOX_BASE_URL=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
PROXMOX_NODE=
PROXMOX_POLL_INTERVAL=5000

# Portainer
# Keep this token server-side only.
PORTAINER_ENABLED=false
PORTAINER_BASE_URL=
PORTAINER_API_KEY=
PORTAINER_POLL_INTERVAL=10000
PORTAINER_STATS_ENABLED=true

# GPU Monitoring (NVIDIA via nvidia-smi)
# GPU_MODE is local or ssh. Use ssh when the dashboard runs away from the GPU host.
GPU_ENABLED=false
GPU_MODE=ssh
GPU_SSH_HOST=
GPU_SSH_USER=
GPU_SSH_PORT=22
GPU_SSH_KEY_PATH=
GPU_POLL_INTERVAL=5000

# Per-node GPU + sensor collection (multi-node Proxmox clusters)
# JSON: node name -> { host, user?, port?, keyPath?, jumpHost?, jumpUser?, jumpPort? }
PROXMOX_NODE_TARGETS=

# UniFi UNAS Configuration (works for UNAS Pro and UNAS 2)
# Use a local UniFi OS admin API key, not a Ubiquiti SSO/cloud account.
UNAS_ENABLED=false
UNAS_BASE_URL=
UNAS_API_KEY=
UNAS_POLL_INTERVAL=30000

# Host sensors (CPU / drive / chipset temps via lm-sensors)
# Empty SSH values inherit the GPU_SSH_* values above.
SENSORS_ENABLED=false
SENSORS_MODE=
SENSORS_SSH_HOST=
SENSORS_SSH_USER=
SENSORS_SSH_PORT=
SENSORS_SSH_KEY_PATH=
SENSORS_POLL_INTERVAL=5000

# SIEM (Syslog ingestion from UniFi network gear)
# Binding UDP 514 can require elevated privileges; use a high port if needed.
SIEM_ENABLED=false
SIEM_PORT=514
SIEM_HOST=0.0.0.0
# Comma-separated IPv4/CIDR allowlist. Unset means localhost only; "*" allows any source.
SIEM_ALLOWED_SOURCES=
SIEM_DB_PATH=./data/siem.sqlite
SIEM_RETENTION_DAYS=30
SIEM_MAX_PER_QUERY=1000

# Intel AMT
# Per-device credentials are configured in the UI; these are global defaults.
AMT_ENABLED=false
AMT_DEFAULT_PORT=16993
AMT_USE_TLS=true
AMT_DEFAULT_USERNAME=admin
AMT_POLL_INTERVAL=15000

# Persistent app state (inventory, thresholds, bookmarks, sidebar, tweaks, etc.)
STATE_DB_PATH=./data/dashboard.sqlite

# Secrets at rest
# Back up data/secret.key with data/. Losing it means stored secrets must be re-entered.
# APP_ENCRYPTION_KEY=        # 64 hex chars (32 bytes), or any passphrase

# Server Configuration
PORT=3001
NODE_ENV=development

# Update check
# Notify-only; set false to stop outbound update checks.
UPDATE_CHECK_ENABLED=true
# UPDATE_REPO=Duresa7/homelab-dashboard-aio
# UPDATE_CHECK_INTERVAL=21600000
# GITHUB_TOKEN=
