# ── Master kill-switch ──────────────────────────────────────────
# Set DISABLE_ALL=true to force every integration off, regardless of the
# individual *_ENABLED flags below. Useful for running the UI standalone
# (e.g. for design work or smoke tests) without any backend gear configured.
DISABLE_ALL=false

# UniFi Controller Configuration
# Set UNIFI_ENABLED=false to disable the integration entirely (no API calls, no errors)
UNIFI_ENABLED=false
UNIFI_BASE_URL=
UNIFI_API_KEY=
UNIFI_SITE=default
UNIFI_POLL_INTERVAL=2000

# Proxmox VE Configuration
# Set PROXMOX_ENABLED=false to disable the integration entirely (no API calls, no errors)
# Create an API token in: Datacenter → Permissions → API Tokens
# TOKEN_ID format: user@realm!tokenname  (e.g. root@pam!dashboard)
PROXMOX_ENABLED=false
PROXMOX_BASE_URL=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
PROXMOX_NODE=
PROXMOX_POLL_INTERVAL=5000

# Docker / Portainer Configuration
# The dashboard talks to Portainer, and Portainer proxies Docker Engine API
# calls to each environment / Edge Agent. Keep this token server-side only.
PORTAINER_ENABLED=false
PORTAINER_BASE_URL=
PORTAINER_API_KEY=
PORTAINER_POLL_INTERVAL=10000
# Set false if you only want up/down/container state without per-container stats.
PORTAINER_STATS_ENABLED=true

# GPU Monitoring (NVIDIA via nvidia-smi)
# Proxmox's API does not expose GPU info, so the backend runs `nvidia-smi` —
# either locally or over SSH — to read it.
#
# GPU_MODE options:
#   "local" — run nvidia-smi on this machine (use when the dashboard itself
#             runs on a host that already has GPU access, e.g. an LXC with
#             passthrough on the Proxmox host). No SSH config needed.
#   "ssh"   — SSH to GPU_SSH_HOST and run nvidia-smi remotely (use when the
#             dashboard runs on a different machine, e.g. dev laptop or a VM
#             without passthrough). Requires an SSH key trusted by the target.
#
# Placement guide:
#   • GPU on Proxmox host, dashboard runs on dev machine          → mode=ssh,   host=Proxmox IP
#   • GPU on Proxmox host, dashboard runs on Proxmox host         → mode=local
#   • GPU passed to LXC (host-shared kernel), dashboard anywhere  → mode=ssh,   host=Proxmox IP
#   • GPU passed to LXC, dashboard runs in that same LXC          → mode=local
#   • GPU passed to VM (VFIO), dashboard anywhere except that VM  → mode=ssh,   host=VM IP
#   • GPU passed to VM, dashboard runs in that same VM            → mode=local
GPU_ENABLED=false
GPU_MODE=ssh
GPU_SSH_HOST=
GPU_SSH_USER=
GPU_SSH_PORT=22
# Absolute path to private key (leave blank to use system default ~/.ssh/id_*).
GPU_SSH_KEY_PATH=
GPU_POLL_INTERVAL=5000

# Per-node GPU + sensor collection (multi-node Proxmox clusters)
# By default the dashboard reads GPU + sensors from the single GPU_SSH_HOST /
# SENSORS_SSH_HOST above and attributes them to PROXMOX_NODE. To collect from
# EVERY node — so the Overview's per-node tiles show which GPU / temps belong to
# which node — map each canonical Proxmox node name to a remote target.
#
# JSON: node name -> { host, user?, port?, keyPath?, jumpHost?, jumpUser?, jumpPort? }
# Omitted fields inherit the GPU_SSH_* defaults above. `jumpHost` is an SSH
# ProxyJump for nodes firewalled from the dashboard host but reachable from a
# peer (common in a cluster — jump through a reachable member). A node with no
# NVIDIA GPU, or no lm-sensors, simply reports none rather than erroring.
#
# Example (3-node cluster; only the first is directly reachable):
#   PROXMOX_NODE_TARGETS={"node-a":{"host":"192.0.2.10"},"node-b":{"host":"192.0.2.11","jumpHost":"192.0.2.10"},"node-c":{"host":"192.0.2.12","jumpHost":"192.0.2.10"}}
PROXMOX_NODE_TARGETS=

# UniFi UNAS Configuration (works for UNAS Pro and UNAS 2)
# The UNAS exposes an undocumented local Drive API. Create a LOCAL
# admin user in UniFi OS → Admins (NOT your Ubiquiti SSO/cloud account),
# then generate an API key on that local user.
# Endpoints polled: /proxy/drive/api/v2/storage, /proxy/drive/api/v2/systems/fan-control, /api/system
UNAS_ENABLED=false
UNAS_BASE_URL=
UNAS_API_KEY=
UNAS_POLL_INTERVAL=30000

# Host sensors (CPU / drive / chipset temps via lm-sensors)
# Same mode pattern as GPU. SSH config falls back to the GPU_SSH_* values
# above if not set here (they almost always target the same host).
# Requires `lm-sensors` installed on the target host:
#   apt install lm-sensors && sensors-detect --auto
SENSORS_ENABLED=false
# SENSORS_MODE=local|ssh  (default: inherits GPU_MODE)
SENSORS_MODE=
SENSORS_SSH_HOST=
SENSORS_SSH_USER=
SENSORS_SSH_PORT=
SENSORS_SSH_KEY_PATH=
SENSORS_POLL_INTERVAL=5000

# SIEM (Syslog ingestion from UniFi network gear)
# Receives RFC 3164 + CEF syslog over UDP on SIEM_PORT (default 514) and stores
# events to SQLite. To set up:
#   1. Set SIEM_ENABLED=true and restart the server.
#   2. In the UniFi Network Application: Settings → System → Remote Logging,
#      enable it and set the server to <this server's LAN IP>:<SIEM_PORT>.
#   3. UniFi will start pushing gateway/firewall, AP, switch, and (on 9.3+)
#      admin / VPN / IDS events.
# On Windows, binding UDP 514 may require an Administrator-elevated terminal.
# If the bind fails, change SIEM_PORT to something above 1024 (e.g. 5514) and
# match it in the UniFi setting.
SIEM_ENABLED=false
SIEM_PORT=514
SIEM_HOST=0.0.0.0
# Which hosts may send syslog. Comma-separated IPv4 addresses and/or CIDR
# ranges, e.g. SIEM_ALLOWED_SOURCES=192.0.2.1,192.0.2.0/24
# Datagrams from any other source IP are dropped. Default-deny: when this is
# unset, the listener binds 127.0.0.1 (localhost only) regardless of SIEM_HOST,
# so remote hosts cannot inject events until senders are explicitly
# allowlisted. Set it to "*" to accept any source (not recommended).
SIEM_ALLOWED_SOURCES=
SIEM_DB_PATH=./data/siem.sqlite
SIEM_RETENTION_DAYS=30
SIEM_MAX_PER_QUERY=1000

# Persistent app state (inventory, thresholds, bookmarks, sidebar, tweaks, etc.)
# SQLite file path. The server creates the file and parent dir on first run.
# Existing browser localStorage entries are auto-migrated into this DB the first
# time the dashboard loads against an empty database.
STATE_DB_PATH=./data/dashboard.sqlite

# ── Secrets at rest ─────────────────────────────────────────────
# Integration API keys/tokens entered in the setup wizard are encrypted with
# AES-256-GCM before they are written to the database. By default the key is
# generated once and stored at data/secret.key (owner-only), so back it up with
# the rest of data/. To keep the key off the data volume (e.g. a Docker secret),
# set it here instead. Losing the key means stored secrets must be re-entered.
#   APP_ENCRYPTION_KEY=        # 64 hex chars (32 bytes), or any passphrase
#
# Alternatively, pick "Environment variable" for an integration in the wizard and
# set its key as its own env var above (e.g. UNIFI_API_KEY); the app then reads
# it from the environment and never stores it.

# Server Configuration
PORT=3001
NODE_ENV=development

# ── Update check ────────────────────────────────────────────────
# The server polls GitHub Releases for a newer version and shows an in-app
# update indicator to admins (notify-only — it never pulls images itself).
# Set false to stop all outbound update checks (also suppressed by DISABLE_ALL).
UPDATE_CHECK_ENABLED=true
# Optional overrides:
#   UPDATE_REPO=Duresa7/homelab-dashboard-aio   # owner/repo to check
#   UPDATE_CHECK_INTERVAL=21600000              # poll interval ms (default 6h)
#   GITHUB_TOKEN=                               # raises GitHub's 60 req/hr/IP limit

# ── Docker deployment notes ─────────────────────────────────────
# The provided docker-compose.yml uses `network_mode: host` so the
# container reaches your LAN directly (real syslog source IPs, no
# unprivileged-port pain). When running under Docker, prefer these:
#
#   SIEM_PORT=514                              # works under host networking
#   GPU_SSH_KEY_PATH=/home/node/.ssh/id_homelab  # match the compose volume
#
# NODE_ENV=production is set by compose, so the value above only matters
# for local `npm run server` development.
